# Токен бота, полученный от @BotFather
BOT_TOKEN=your_bot_token_here

# ID канала Барахолка (можно узнать через @userinfobot, переслав сообщение из канала)
CHANNEL_ID=@your_channel_username_or_id

# Приветственное сообщение (опционально, есть дефолтное)
# WELCOME_MESSAGE=Привет! Добро пожаловать в Барахолку!

# Таймаут капчи в секундах (по умолчанию 300 = 5 минут)
# CAPTCHA_TIMEOUT=300

# Максимум попыток прохождения капчи (по умолчанию 3)
# MAX_ATTEMPTS=3
